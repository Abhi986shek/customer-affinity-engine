AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

ECR_REPO_URI=your-account.dkr.ecr.us-east-1.amazonaws.com/customer-affinity-engine
IMAGE_TAG=latest

SAGEMAKER_ROLE_ARN=arn:aws:iam::your-account-id:role/SageMakerRole
SAGEMAKER_ENDPOINT_NAME=customer-affinity-endpoint
SAGEMAKER_INSTANCE_TYPE=ml.m5.xlarge

MODEL_ARTIFACT_S3_URI=s3://your-bucket/models/affinity/model.tar.gz
S3_BUCKET_NAME=your-s3-bucket-name
S3_DATA_PREFIX=data/customer-behavior/
S3_MODEL_PREFIX=models/affinity/

DATABASE_URL=postgresql://user:password@localhost:5432/customer_affinity

MODEL_N_ESTIMATORS=300
MODEL_MAX_DEPTH=6
MODEL_LEARNING_RATE=0.05
MODEL_SUBSAMPLE=0.8
MODEL_COLSAMPLE_BYTREE=0.8
